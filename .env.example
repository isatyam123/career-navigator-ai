# Browser-visible (safe to expose)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-publishable-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Server-only (used by TanStack server functions / SSR)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-anon-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # Secret! From Supabase → Settings → API
SUPABASE_PROJECT_ID=<your-project-ref>

# Google Gemini (used by resume analyzer, email generator, interview questions).
# Set your Google Gemini API key here
GEMINI_API_KEY=<your-gemini-api-key>
